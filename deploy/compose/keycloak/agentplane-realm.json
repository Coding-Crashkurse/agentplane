{
  "realm": "agentplane",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "agentplane platform admin"
      },
      {
        "name": "user",
        "description": "agentplane platform user"
      },
      {
        "name": "builder",
        "description": "agentplane flow builder"
      }
    ]
  },
  "groups": [
    {
      "name": "platform-admins",
      "path": "/platform-admins",
      "realmRoles": [
        "admin"
      ],
      "clientRoles": {
        "realm-management": [
          "view-users",
          "query-users",
          "manage-users",
          "view-realm"
        ]
      }
    },
    {
      "name": "acme",
      "path": "/acme"
    }
  ],
  "users": [
    {
      "username": "demo-admin",
      "enabled": true,
      "email": "demo-admin@example.com",
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "user",
        "builder"
      ],
      "groups": [
        "/platform-admins",
        "/acme"
      ]
    },
    {
      "username": "demo-user",
      "enabled": true,
      "email": "demo-user@example.com",
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "user",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "demo-builder",
      "enabled": true,
      "email": "demo-builder@example.com",
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Builder",
      "credentials": [
        {
          "type": "password",
          "value": "builder",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "builder"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "agentplane-cli",
      "name": "agentplane CLI / smoke tests",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "agentplane-cli-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "defaultClientScopes": [
        "basic",
        "roles",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "agentplane",
            "access.token.claim": "true"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "agentplane-ui",
      "name": "agentplane portal (SPA)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://app.localhost/*"
      ],
      "webOrigins": [
        "http://app.localhost"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://app.localhost/*"
      },
      "defaultClientScopes": [
        "basic",
        "roles",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "agentplane",
            "access.token.claim": "true"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "agentplane-builder",
      "name": "agentplane builder (SPA)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://builder.localhost/*"
      ],
      "webOrigins": [
        "http://builder.localhost"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://builder.localhost/*"
      },
      "defaultClientScopes": [
        "basic",
        "roles",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "agentplane",
            "access.token.claim": "true"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "agentplane",
      "name": "agentplane audience",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false
    },
    {
      "clientId": "langfuse",
      "name": "Langfuse SSO",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "langfuse-client-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://langfuse.localhost/api/auth/callback/custom"
      ],
      "webOrigins": [
        "http://langfuse.localhost"
      ],
      "defaultClientScopes": [
        "basic",
        "roles",
        "profile",
        "email",
        "web-origins"
      ]
    }
  ],
  "defaultRoles": [
    "user"
  ]
}