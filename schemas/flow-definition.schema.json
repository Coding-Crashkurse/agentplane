{
  "$defs": {
    "A2aAgentRef": {
      "additionalProperties": false,
      "description": "One sub-agent an orchestrator may call, referenced by registry card name.\n\nOnly A2A agents already registered in the platform registry can be\nreferenced \u2014 the runtime resolves the name to the agent's gateway URL, so\ndelegated calls stay authenticated, rate-limited, and traced. URLs never\nappear in definitions (they are environment-specific; names are not).",
      "properties": {
        "name": {
          "description": "Registry card name of a deployed A2A agent",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "A2aAgentRef",
      "type": "object"
    },
    "AgentNode": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "$ref": "#/$defs/AgentNodeConfig"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "agent",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "version",
        "type",
        "config"
      ],
      "title": "AgentNode",
      "type": "object"
    },
    "AgentNodeConfig": {
      "additionalProperties": false,
      "description": "LLM + tool loop (v1.1): the model calls MCP tools until it answers.\n\nThe prompt's ``{vars}`` become input ports (like ``llm_call``). Each turn the\nmodel may emit tool calls (OpenAI tool-calling); the runtime runs them via\nMCP and feeds the results back, up to ``max_iterations``, then returns the\nfinal assistant text.\n\n``agents`` turns the node into an orchestrator: each referenced registry\nagent is offered to the model as an additional tool whose description comes\nfrom the agent's card; a call is delegated over A2A through the gateway.",
      "properties": {
        "agents": {
          "description": "A2A agents (registry card names) the model may delegate to; resolved through the registry, called through the gateway.",
          "items": {
            "$ref": "#/$defs/A2aAgentRef"
          },
          "title": "Agents",
          "type": "array"
        },
        "max_iterations": {
          "default": 6,
          "description": "Cap on tool-call turns before forcing a final answer.",
          "maximum": 50,
          "minimum": 1,
          "title": "Max Iterations",
          "type": "integer"
        },
        "model": {
          "default": "",
          "title": "Model",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "resource": {
          "description": "ModelProvider resource",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
          "title": "Resource",
          "type": "string"
        },
        "system_prompt": {
          "default": "",
          "title": "System Prompt",
          "type": "string"
        },
        "tools": {
          "items": {
            "$ref": "#/$defs/AgentToolRef"
          },
          "title": "Tools",
          "type": "array"
        }
      },
      "required": [
        "resource",
        "prompt"
      ],
      "title": "AgentNodeConfig",
      "type": "object"
    },
    "AgentToolRef": {
      "additionalProperties": false,
      "description": "One tool an agent may call: an MCP server resource, optionally narrowed.",
      "properties": {
        "resource": {
          "description": "McpServer resource the tool(s) live on",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
          "title": "Resource",
          "type": "string"
        },
        "tool": {
          "default": "",
          "description": "Specific tool name; empty = every tool the server exposes",
          "title": "Tool",
          "type": "string"
        }
      },
      "required": [
        "resource"
      ],
      "title": "AgentToolRef",
      "type": "object"
    },
    "Edge": {
      "additionalProperties": false,
      "properties": {
        "from": {
          "title": "From",
          "type": "string"
        },
        "to": {
          "title": "To",
          "type": "string"
        }
      },
      "required": [
        "from",
        "to"
      ],
      "title": "Edge",
      "type": "object"
    },
    "EndNode": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "$ref": "#/$defs/EndNodeConfig"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "end",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "version",
        "type",
        "config"
      ],
      "title": "EndNode",
      "type": "object"
    },
    "EndNodeConfig": {
      "additionalProperties": false,
      "properties": {
        "output_from": {
          "default": "",
          "description": "Reference 'node_id.port' the flow output is read from. Empty means: take the value wired into the `input` port \u2014 required for branched flows where different runs feed `end` from different nodes.",
          "title": "Output From",
          "type": "string"
        }
      },
      "title": "EndNodeConfig",
      "type": "object"
    },
    "ExposeConfig": {
      "additionalProperties": false,
      "description": "How the runtime serves a flow: as an A2A agent or as an MCP server.",
      "properties": {
        "examples": {
          "description": "Example prompts for this flow. Served as `skill.examples` on the A2A agent card so calling agents can route to it.",
          "items": {
            "type": "string"
          },
          "title": "Examples",
          "type": "array"
        },
        "kind": {
          "enum": [
            "a2a",
            "mcp"
          ],
          "title": "Kind",
          "type": "string"
        },
        "tool_description": {
          "default": "",
          "title": "Tool Description",
          "type": "string"
        },
        "tool_name": {
          "anyOf": [
            {
              "pattern": "^[a-z][a-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Name"
        }
      },
      "required": [
        "kind"
      ],
      "title": "ExposeConfig",
      "type": "object"
    },
    "JsonValue": {},
    "Layout": {
      "additionalProperties": true,
      "description": "Canvas layout block \u2014 builder-owned, ignored by the runtime.",
      "properties": {
        "nodes": {
          "additionalProperties": {
            "$ref": "#/$defs/LayoutPosition"
          },
          "title": "Nodes",
          "type": "object"
        }
      },
      "title": "Layout",
      "type": "object"
    },
    "LayoutPosition": {
      "additionalProperties": true,
      "description": "Canvas position \u2014 builder-owned, ignored by the runtime.",
      "properties": {
        "x": {
          "default": 0,
          "title": "X",
          "type": "number"
        },
        "y": {
          "default": 0,
          "title": "Y",
          "type": "number"
        }
      },
      "title": "LayoutPosition",
      "type": "object"
    },
    "LlmCallNode": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "$ref": "#/$defs/LlmCallNodeConfig"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "llm_call",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "version",
        "type",
        "config"
      ],
      "title": "LlmCallNode",
      "type": "object"
    },
    "LlmCallNodeConfig": {
      "additionalProperties": false,
      "properties": {
        "history": {
          "default": false,
          "description": "Prepend the conversation history as chat messages. The history is the prior turns of the caller's conversation (A2A contextId), loaded by the runtime from its task store; with history disabled or no persistence the node sees only the current prompt.",
          "title": "History",
          "type": "boolean"
        },
        "history_max_turns": {
          "default": 20,
          "description": "Cap on prior exchanges (user + assistant pairs) fed to the model.",
          "maximum": 200,
          "minimum": 1,
          "title": "History Max Turns",
          "type": "integer"
        },
        "model": {
          "default": "",
          "title": "Model",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "resource": {
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
          "title": "Resource",
          "type": "string"
        },
        "stream": {
          "default": false,
          "title": "Stream",
          "type": "boolean"
        },
        "structured_output": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Structured Output"
        },
        "system_prompt": {
          "default": "",
          "title": "System Prompt",
          "type": "string"
        }
      },
      "required": [
        "resource",
        "prompt"
      ],
      "title": "LlmCallNodeConfig",
      "type": "object"
    },
    "McpToolNode": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "$ref": "#/$defs/McpToolNodeConfig"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "mcp_tool",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "version",
        "type",
        "config"
      ],
      "title": "McpToolNode",
      "type": "object"
    },
    "McpToolNodeConfig": {
      "additionalProperties": false,
      "properties": {
        "args": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "input port name -> tool argument name",
          "title": "Args",
          "type": "object"
        },
        "resource": {
          "anyOf": [
            {
              "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resource"
        },
        "tool": {
          "title": "Tool",
          "type": "string"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        }
      },
      "required": [
        "tool"
      ],
      "title": "McpToolNodeConfig",
      "type": "object"
    },
    "RerankNode": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "$ref": "#/$defs/RerankNodeConfig"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "rerank",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "version",
        "type",
        "config"
      ],
      "title": "RerankNode",
      "type": "object"
    },
    "RerankNodeConfig": {
      "additionalProperties": false,
      "description": "Reorder retrieved documents by relevance to the query (v1.1).\n\nThe retrieval node returns a similarity top-k; a reranker (cross-encoder)\nthen scores each document against the query directly and keeps the best\n``top_n`` \u2014 the standard quality step between retrieval and the LLM. Reuses\na ``model_provider`` resource whose ``base_url`` serves a ``/rerank``\nendpoint (Cohere/Jina/TEI-style); no new resource kind.",
      "properties": {
        "min_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Rerank score threshold; documents scoring below it are dropped, so a reranked set can be empty (which lets an empty-result router branch fire). Score scale is the reranker's own relevance score, not the retrieval metric.",
          "title": "Min Score"
        },
        "model": {
          "default": "",
          "title": "Model",
          "type": "string"
        },
        "resource": {
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
          "title": "Resource",
          "type": "string"
        },
        "top_n": {
          "default": 4,
          "maximum": 100,
          "minimum": 1,
          "title": "Top N",
          "type": "integer"
        }
      },
      "required": [
        "resource"
      ],
      "title": "RerankNodeConfig",
      "type": "object"
    },
    "RetrievalNode": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "$ref": "#/$defs/RetrievalNodeConfig"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "retrieval",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "version",
        "type",
        "config"
      ],
      "title": "RetrievalNode",
      "type": "object"
    },
    "RetrievalNodeConfig": {
      "additionalProperties": false,
      "properties": {
        "collection": {
          "title": "Collection",
          "type": "string"
        },
        "filter": {
          "anyOf": [
            {
              "additionalProperties": {
                "$ref": "#/$defs/JsonValue"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Filter"
        },
        "min_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Similarity score threshold. Hits below it are dropped, so a filled collection can still yield zero documents \u2014 which is what makes an empty-result router branch fire. Score semantics follow the collection's distance metric (cosine: 1.0 = identical).",
          "title": "Min Score"
        },
        "resource": {
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
          "title": "Resource",
          "type": "string"
        },
        "top_k": {
          "default": 4,
          "maximum": 100,
          "minimum": 1,
          "title": "Top K",
          "type": "integer"
        }
      },
      "required": [
        "resource",
        "collection"
      ],
      "title": "RetrievalNodeConfig",
      "type": "object"
    },
    "RouterNode": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "$ref": "#/$defs/RouterNodeConfig"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "router",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "version",
        "type",
        "config"
      ],
      "title": "RouterNode",
      "type": "object"
    },
    "RouterNodeConfig": {
      "additionalProperties": false,
      "description": "Conditional branching (v1.1): routes the input value to one branch.\n\nEvery rule branch plus the default branch becomes a typed output port\nthat passes the input value through; only the chosen branch's downstream\nnodes execute.",
      "properties": {
        "default_branch": {
          "default": "otherwise",
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Default Branch",
          "type": "string"
        },
        "input_type": {
          "default": "text",
          "enum": [
            "text",
            "json",
            "documents"
          ],
          "title": "Input Type",
          "type": "string"
        },
        "rules": {
          "items": {
            "$ref": "#/$defs/RouterRule"
          },
          "minItems": 1,
          "title": "Rules",
          "type": "array"
        }
      },
      "required": [
        "rules"
      ],
      "title": "RouterNodeConfig",
      "type": "object"
    },
    "RouterRule": {
      "additionalProperties": false,
      "description": "One branch condition, evaluated in order; first match wins.\n\n``path`` (dot notation, JSON inputs only) selects the value under test \u2014\nempty means the whole input. ``equals``/``not_equals`` compare it to\n``value``; ``contains`` is substring/membership/key test; ``gt``/``gte``/\n``lt``/``lte`` compare numerically. A missing path resolves to null: it\nmatches ``empty`` and never matches a comparison.",
      "properties": {
        "branch": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Branch",
          "type": "string"
        },
        "path": {
          "default": "",
          "description": "Dot path into a JSON input selecting the value under test; empty = input.",
          "title": "Path",
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/JsonValue",
          "default": null,
          "description": "Comparison operand; required for every condition except empty/not_empty."
        },
        "when": {
          "enum": [
            "not_empty",
            "empty",
            "equals",
            "not_equals",
            "contains",
            "gt",
            "gte",
            "lt",
            "lte"
          ],
          "title": "When",
          "type": "string"
        }
      },
      "required": [
        "when",
        "branch"
      ],
      "title": "RouterRule",
      "type": "object"
    },
    "StartNode": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "$ref": "#/$defs/StartNodeConfig"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "start",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "version",
        "type",
        "config"
      ],
      "title": "StartNode",
      "type": "object"
    },
    "StartNodeConfig": {
      "additionalProperties": false,
      "properties": {
        "input_schema": {
          "additionalProperties": true,
          "title": "Input Schema",
          "type": "object"
        }
      },
      "required": [
        "input_schema"
      ],
      "title": "StartNodeConfig",
      "type": "object"
    },
    "TemplateNode": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "$ref": "#/$defs/TemplateNodeConfig"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "template",
          "title": "Type",
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "version",
        "type",
        "config"
      ],
      "title": "TemplateNode",
      "type": "object"
    },
    "TemplateNodeConfig": {
      "additionalProperties": false,
      "description": "Static/interpolated text (v1.1): `{vars}` become input ports.\n\nThe `trigger` input port exists on every template so a router branch can\nactivate it even when the text needs no variables (fallback messages).",
      "properties": {
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "TemplateNodeConfig",
      "type": "object"
    }
  },
  "$id": "https://agentplane.dev/schemas/flow-definition.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Versioned, serializable description of a flow (SPEC \u00a73.1).\n\nSerialization is deterministic: nodes are sorted by id, edges by\n(from, to), keys stay in model order \u2014 ``parse(serialize(d)) == d``.",
  "properties": {
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "display_name": {
      "default": "",
      "title": "Display Name",
      "type": "string"
    },
    "edges": {
      "items": {
        "$ref": "#/$defs/Edge"
      },
      "title": "Edges",
      "type": "array"
    },
    "expose": {
      "$ref": "#/$defs/ExposeConfig"
    },
    "layout": {
      "anyOf": [
        {
          "$ref": "#/$defs/Layout"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "name": {
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
      "title": "Name",
      "type": "string"
    },
    "nodes": {
      "items": {
        "discriminator": {
          "mapping": {
            "agent": "#/$defs/AgentNode",
            "end": "#/$defs/EndNode",
            "llm_call": "#/$defs/LlmCallNode",
            "mcp_tool": "#/$defs/McpToolNode",
            "rerank": "#/$defs/RerankNode",
            "retrieval": "#/$defs/RetrievalNode",
            "router": "#/$defs/RouterNode",
            "start": "#/$defs/StartNode",
            "template": "#/$defs/TemplateNode"
          },
          "propertyName": "type"
        },
        "oneOf": [
          {
            "$ref": "#/$defs/StartNode"
          },
          {
            "$ref": "#/$defs/EndNode"
          },
          {
            "$ref": "#/$defs/LlmCallNode"
          },
          {
            "$ref": "#/$defs/AgentNode"
          },
          {
            "$ref": "#/$defs/McpToolNode"
          },
          {
            "$ref": "#/$defs/RetrievalNode"
          },
          {
            "$ref": "#/$defs/RerankNode"
          },
          {
            "$ref": "#/$defs/RouterNode"
          },
          {
            "$ref": "#/$defs/TemplateNode"
          }
        ]
      },
      "title": "Nodes",
      "type": "array"
    },
    "schema_version": {
      "title": "Schema Version",
      "type": "integer"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "name",
    "expose",
    "nodes"
  ],
  "title": "FlowDefinition",
  "type": "object"
}
